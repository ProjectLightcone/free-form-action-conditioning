---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'TEPA Whitepaper',
	description = 'A Tri-Embedding Predictive Architecture for instruction-conditioned world modeling.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background: oklch(97.5% 0.006 242);
		color: oklch(20% 0.025 248);
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	::selection {
		background: oklch(83% 0.08 205);
		color: oklch(18% 0.03 248);
	}
</style>
